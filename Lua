    if not BotESP_Enabled then
        for ent, d in pairs(BotESP_Pool) do
            for _, drawing in pairs(d) do pcall(function() drawing.Visible = false end) end
        end
        return
    end

    local world = Workspace:FindFirstChild('World')
    if not world then return end
    local entities = world:FindFirstChild('Entities')
    if not entities then return end

    for ent, d in pairs(BotESP_Pool) do
        if not ent.Parent then
            for _, drawing in pairs(d) do pcall(function() drawing:Remove() end) end
            BotESP_Pool[ent] = nil
        end
    end

    for _, ent in ipairs(entities:GetChildren()) do
        if ent:GetAttribute('IsDummy') ~= true then continue end
        local hrp = ent:FindFirstChild('HumanoidRootPart')
        if not hrp then continue end
        local root_pos, root_visible = World_To_Screen(hrp.Position)
        local head = ent:FindFirstChild('Head')
        local head_pos, head_visible
        if head then head_pos, head_visible = World_To_Screen(head.Position + v3_new(0, 0.5, 0)) end

        if not root_visible and not head_visible then
            if BotESP_Pool[ent] then
                for _, drawing in pairs(BotESP_Pool[ent]) do drawing.Visible = false end
            end
            continue
        end

        local isFinisher = ent:GetAttribute('Finisher') == true
        local color = isFinisher and BotESP_FinisherColor or BotESP_Color

        if not BotESP_Pool[ent] then BotESP_Pool[ent] = Create_Bot_Drawings() end
        local d = BotESP_Pool[ent]

        local head_y = head_pos and head_pos.Y or (root_pos.Y - 3)
        local root_y = root_pos.Y + 2
        local height = math_abs(root_y - head_y)
        local width = height * 0.55
        local box_x = root_pos.X - width / 2
        local box_y = head_y - 2

        d.Box.Position = v2_new(box_x, box_y)
        d.Box.Size = v2_new(width, height)
        d.Box.Color = color
        d.Box.Visible = true

        local label_text = isFinisher and 'BOT [FINISHER]' or 'BOT'
        if BotESP_ShowID then
            local botID = ent:GetAttribute('BotUserId')
            label_text = label_text .. ' #' .. tostring(botID or '?')
        end
        d.Label.Text = label_text
        d.Label.Position = v2_new(root_pos.X, box_y - 14)
        d.Label.Color = color
        d.Label.Visible = true

        if head_pos and head_visible then
            d.Dot.Position = head_pos
            d.Dot.Color = color
            d.Dot.Visible = true
        else
            d.Dot.Visible = false
        end
    end
end

