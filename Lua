local function SetupKillFeedListener()
    task.delay(4, function()
        pcall(function()
            if Neuron and Neuron.net and Neuron.net.packets then
                local packet = Neuron.net.packets.round_died
                if packet and packet.Connect then
                    packet:Connect(function(data)
                        if not KF_Enabled then return end
                        if not data then return end
                        local killed = data.player
                        local killer = data.killer
                        local assist = data.assistingPlayer
                        local headshot = data.headShot
                        local weaponID = data.weaponID
                        if not killed then return end

                        local killerName = killer and killer.DisplayName or "World"
                        local killedName = killed.DisplayName
                        local assistName = assist and assist.DisplayName or nil

                        local weaponName = weaponID or "weapon"
                        local weaponAliases = {
                            ["burst"] = "Burst Carbine", ["handgun"] = "Pistol", ["tec9"] = "Tec-9", ["flintlock"] = "Flintlock",
                            ["bolt_action_sniper"] = "Sniper", ["taser"] = "Tazer", ["satchel"] = "Satchel", ["fist"] = "Knife",
                            ["ak47"] = "AK-47", ["ar"] = "Assault Rifle", ["deagle"] = "Desert Eagle", ["minigun"] = "Minigun",
                            ["pistol"] = "Pistol", ["pulse_rifle"] = "Pulse Rifle", ["raygun"] = "Ray Gun", ["rpg"] = "RPG",
                            ["shotgun"] = "Shotgun", ["sniper"] = "Sniper", ["scar_h"] = "SCAR-H", ["lmg"] = "LMG",
                            ["tommy_gun"] = "Tommy Gun", ["knife"] = "Knife", ["karambit"] = "Karambit", ["katana"] = "Katana",
                            ["butterfly_knife"] = "Butterfly Knife", ["scythe"] = "Scythe", ["shorty"] = "Shorty",
                            ["grenade"] = "Grenade", ["molotov"] = "Molotov", ["precision_burst_carbine"] = "Burst Carbine",
                            ["tazer"] = "Tazer", ["satchel_explosive"] = "Satchel", ["flintlock_pistol"] = "Flintlock", ["tec-9"] = "Tec-9",
                        }
                        if weaponAliases[weaponName] then weaponName = weaponAliases[weaponName] end

                        local text = killerName .. " > " .. killedName .. " [" .. weaponName .. "]"
                        if headshot then text = text .. " [HS]" end
                        if assistName then text = text .. " (+ " .. assistName .. ")" end

                        local entry = Drawing.new('Text')
                        entry.Text = text; entry.Size = 14; entry.Center = false; entry.Outline = true; entry.Font = Drawing.Fonts.Plex
                        entry.Color = headshot and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 255, 255)
                        entry.Visible = true

                        table.insert(KF_Pool, { drawing = entry, expire = tick() + KF_Duration, duration = KF_Duration })
                        while #KF_Pool > KF_MaxEntries do
                            local old = table.remove(KF_Pool, 1)
                            pcall(function() old.drawing:Remove() end)
                        end
                    end)
                end
            end
        end)
    end)
end

SetupKillFeedListener()

local function Update_KillFeed()
    local now = tick()
    local screen_size = Camera.ViewportSize
    local y_start = 150
    for i = #KF_Pool, 1, -1 do
        local entry = KF_Pool[i]
        if now > entry.expire then
            pcall(function() entry.drawing:Remove() end)
            table.remove(KF_Pool, i)
        else
            local remaining = (entry.expire - now) / entry.duration
            local fade = math.clamp(remaining * 2, 0, 1)
            entry.drawing.Position = v2_new(screen_size.X - 350, y_start + (#KF_Pool - i) * 20)
            entry.drawing.Transparency = 1 - fade
        end
    end
end

-- DEVICE CHANGER
local function TryHookDataHandler()
    if DC_Hooked then return end
    if not DataHandler then return end
    if not DataHandler.GetDataAsync then return end
    pcall(function()
        local original = DataHandler.GetDataAsync
        DataHandler.GetDataAsync = function(self, player, ...)
            local result = original(self, player, ...)
            if player == LocalPlayer and DC_Enabled and result then
                result.Device = DC_Device == "default" and nil or tonumber(DC_Device)
            end
            return result
        end
        DC_Hooked = true
    end)
end

task.delay(4.5, function() TryHookDataHandler() end)

local function Update_DeviceChanger()
    if not DC_Enabled then return end
    if not GameplayHandler then return end
    pcall(function()
        if GameplayHandler.playerFrame then
            local deviceFrame = GameplayHandler.playerFrame:FindFirstChild("Device")
            if deviceFrame then
                local icon = deviceFrame:FindFirstChild("Icon")
                if icon and icon:IsA("ImageLabel") then
                    local deviceOffsets = {
                        ["1"] = { Vector2.new(104, 154), Vector2.new(48, 72) },
                        ["2"] = { Vector2.new(166, 154), Vector2.new(102, 72) },
                        ["default"] = { Vector2.new(0, 154), Vector2.new(90, 72) }
                    }
                    local offset = deviceOffsets[DC_Device] or deviceOffsets["default"]
                    icon.ImageRectOffset = offset[1]
                    icon.ImageRectSize = offset[2]
                end
            end
        end
    end)
end

