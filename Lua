-- MATRIX AIMBOT LOGIC
local function IsTargetValid(player)
    if not player then return false end
    if player == LocalPlayer then return false end
    if IsSameTeam(player) then return false end
    if not IsAlive(player) then return false end
    resolve_player(player)
    local char = player.Character
    if not char then return false end
    local target_part = Get_Nearest_Part(player, Aimbot_Part)
    if not target_part then return false end
    
    if not Aimbot_NoSleep and Aimbot_Visible_Check then
        if Is_Behind_Wall(target_part) then return false end
    end
    
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return false end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local dist = (screen_pos - screen_center).Magnitude
    if dist > Aim_FOV then return false end
    return true
end

local function GetScreenDistance(player)
    local target_part = Get_Nearest_Part(player, Aimbot_Part)
    if not target_part then return math.huge end
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return math.huge end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    return (screen_pos - screen_center).Magnitude
end

local function Get_Closest_Target()
    local closest_player = nil
    local closest_distance = Aim_FOV

    if Aimbot_LockTarget and Aim_CurrentTarget and Aim_CurrentTarget.Parent then
        if IsTargetValid(Aim_CurrentTarget) then
            local current_dist = GetScreenDistance(Aim_CurrentTarget)
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= Aim_CurrentTarget and IsTargetValid(player) then
                    local new_dist = GetScreenDistance(player)
                    if new_dist < current_dist * 0.6 then
                        closest_player = player
                        closest_distance = new_dist
                    end
                end
            end
            if closest_player then return closest_player end
            return Aim_CurrentTarget
        end
    end

    Aim_CurrentTarget = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if IsTargetValid(player) then
            local dist = GetScreenDistance(player)
            if dist < closest_distance then
                closest_distance = dist
                closest_player = player
            end
        end
    end
    return closest_player
end

local function isKeybindActive()
    if not Aimbot_Enabled then return false end
    local kb = Options.Aimbot_Key
    if not kb or kb.Value == Enum.KeyCode.Unknown then return true end
    if Aimbot_ToggleMode then
        return Toggles.Aimbot_Key.Value
    else
        return kb:GetState()
    end
end

local function Update_Aimbot()
    if not isKeybindActive() then
        Aim_CurrentTarget = nil
        return
    end

    Aim_CurrentTarget = Get_Closest_Target()

    if Aim_CurrentTarget then
        local char = Aim_CurrentTarget.Character
        if not char then return end
        local target_part = Get_Nearest_Part(Aim_CurrentTarget, Aimbot_Part)
        if not target_part then return end

        local targetPos = target_part.Position
        if Aimbot_Predict then
            local vel = target_part.AssemblyLinearVelocity
            targetPos = targetPos + Vector3.new(vel.X * Aimbot_PredictX, vel.Y * Aimbot_PredictY, vel.Z * Aimbot_PredictX)
        end

        if Aimbot_Resolve then
            -- Slight offset up to compensate for hitbox desync
            targetPos = targetPos + Vector3.new(0, 0.1, 0)
        end

        local screenPos, onScreen = World_To_Screen(targetPos)
        if onScreen then
            local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            local deltaX = screenPos.X - center.X
            local deltaY = screenPos.Y - center.Y
            
            local alpha = Aimbot_Smoothness
            if Aimbot_Easing then
                alpha = 1 - math.pow(1 - Aimbot_Smoothness, 3)
            end
            
            local moveX = deltaX * alpha
            local moveY = deltaY * alpha
            
            if Aimbot_Shake then
                moveX = moveX + (math_random() - 0.5) * 2
                moveY = moveY + (math_random() - 0.5) * 2
            end
            
            if mousemoverel then mousemoverel(moveX, moveY) end
        end
    end
end

-- ESP UPDATE
local function Update_ESP()
    Cleanup_ESP()
    local screen_size = Camera.ViewportSize
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if IsSameTeam(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then
            local d = ESP_Pool[player]
            if d then for _, drawing in pairs(d) do drawing.Visible = false end end
            continue
        end

        local hrp = char:FindFirstChild('HumanoidRootPart')
        local head = char:FindFirstChild('Head')
        if not hrp or not head then
            local d = ESP_Pool[player]
            if d then for _, drawing in pairs(d) do drawing.Visible = false end end
            continue
        end

        local root_pos, root_visible = World_To_Screen(hrp.Position)
        local head_pos, head_visible = World_To_Screen(head.Position + v3_new(0, 0.3, 0))

        local d = ESP_Pool[player]
        if not d then d = Create_ESP_Drawings(player) end

        if not root_visible and not head_visible then
            for _, drawing in pairs(d) do drawing.Visible = false end
            continue
        end

        local health = Get_Health(player)
        local distance = Get_Distance(player)
        local dist_str = tostring(math_floor(distance)) .. 'm'

        local effective_box_color = Box_Color
        local effective_name_color = Name_Color
        local effective_tracer_color = Tracer_Color
        local effective_dot_color = Head_Dot_Color

        if ESP_TeamColors then
            local tColor = GetTeamColor(player)
            if tColor then
                effective_box_color = tColor
                effective_name_color = tColor
                effective_tracer_color = tColor
                effective_dot_color = tColor
            end
        end

        local head_size = 2
        local head_y = head_pos.Y - head_size
        local root_y = root_pos.Y + 2
        local height = math_abs(root_y - head_y)
        local width = height * 0.55
        local box_x = root_pos.X - width / 2
        local box_y = head_pos.Y - head_size

        if Box_Enabled and ESP_Enabled then
            d.Box_Outline.Position = v2_new(box_x, box_y)
            d.Box_Outline.Size = v2_new(width, height)
            d.Box_Outline.Visible = true
            d.Box_Outline.Color = effective_box_color
            d.Box_Fill.Position = v2_new(box_x, box_y)
            d.Box_Fill.Size = v2_new(width, height)
            d.Box_Fill.Visible = true
        else
            d.Box_Outline.Visible = false
            d.Box_Fill.Visible = false
        end

        if Health_Enabled and ESP_Enabled then
            local bar_x = box_x - 6
            d.Health_Bar_BG.From = v2_new(bar_x, box_y)
            d.Health_Bar_BG.To = v2_new(bar_x, box_y + height)
            d.Health_Bar_BG.Visible = true
            local filled = height * health
            d.Health_Bar.From = v2_new(bar_x, box_y + height - filled)
            d.Health_Bar.To = v2_new(bar_x, box_y + height)
            d.Health_Bar.Visible = true
            local r = (1 - health) * 255
            local g = health * 255
            d.Health_Bar.Color = Color3.fromRGB(r, g, 40)
        else
            d.Health_Bar_BG.Visible = false
            d.Health_Bar.Visible = false
        end

        if Name_Enabled and ESP_Enabled then
            d.Name_Text.Text = player.DisplayName
            d.Name_Text.Position = v2_new(root_pos.X, box_y - 14)
            d.Name_Text.Visible = true
            d.Name_Text.Color = effective_name_color
        else
            d.Name_Text.Visible = false
        end

        if Distance_Enabled and ESP_Enabled then
            d.Distance_Text.Text = dist_str
            d.Distance_Text.Position = v2_new(root_pos.X, box_y + height + 4)
            d.Distance_Text.Visible = true
        else
            d.Distance_Text.Visible = false
        end

        if ESP_MatchAware or ESP_SpectateDetect then
            local status_parts = {}
            if ESP_MatchAware then
                local matchState = GetPlayerMatchState(player)
                if matchState ~= "unknown" then table.insert(status_parts, matchState) end
            end
            if ESP_SpectateDetect and IsPlayerSpectating(player) then table.insert(status_parts, "SPECTATING") end
            if #status_parts > 0 then
                d.Status_Text.Text = table.concat(status_parts, " | ")
                d.Status_Text.Position = v2_new(root_pos.X, box_y + height + 18)
                d.Status_Text.Color = IsPlayerSpectating(player) and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(150, 150, 255)
                d.Status_Text.Visible = true
            else
                d.Status_Text.Visible = false
            end
        else
            d.Status_Text.Visible = false
        end

        if Tracer_Enabled and ESP_Enabled then
            local origin_x = screen_size.X / 2
            local origin_y = Tracer_Origin == 'Bottom' and screen_size.Y or Tracer_Origin == 'Top' and 0 or screen_size.Y / 2
            d.Tracer_Line.From = v2_new(origin_x, origin_y)
            d.Tracer_Line.To = v2_new(root_pos.X, root_pos.Y)
            d.Tracer_Line.Visible = true
            d.Tracer_Line.Color = effective_tracer_color
        else
            d.Tracer_Line.Visible = false
        end

        if Head_Dot_Enabled and ESP_Enabled then
            d.Head_Dot.Position = head_pos
            d.Head_Dot.Visible = true
            d.Head_Dot.Color = effective_dot_color
        else
            d.Head_Dot.Visible = false
        end
    end
end

